<div class="container mt-4">
  <p><strong>Date:</strong> {{selectedDate}}</p>

  <!-- Time Selection Form -->
  <form id="timeSelectForm" method="GET" action="/reserve-lab/{{lab._id}}">
    <div class="row mb-3">
      <div class="col-md-4">
        <label for="timeSelect" class="form-label">Select Time:</label>
        <select id="timeSelect" class="form-select" name="time">
          {{#each timeSlots}}
          <option value="{{this}}" {{#eq selectedTime this}}selected{{/eq}}>{{this}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </form>

  <!-- Seat Grid (Buttons) -->
  <div id="seatGrid" class="mb-4">
    <div class="row">
      {{#each flattenedSeats}}
        {{#if (eq time ../selectedTime)}} <!-- Only show the selected time -->
          <div class="col-md-2 col-3 mb-2">
            <button id="seat-{{seatNumber}}-{{time}}" class="btn seat-btn
              {{#if reserved}}btn-outline-danger{{else}}btn-outline-primary{{/if}} w-100"
              data-seat="{{seatNumber}}" data-time="{{time}}" {{#if reserved}}disabled{{/if}} 
              onclick="toggleSeatSelection({{seatNumber}}, '{{time}}')">
              {{#if reserved}} <!-- Show "Reserved" for reserved seats -->
                Reserved
              {{else}}
                {{seatNumber}} <!-- Show seat number for available seats -->
              {{/if}}
            </button>
          </div>
        {{/if}}
      {{/each}}
    </div>
  </div>

  <!-- Submit Reservation -->
  <div class="text-center">
    <button id="confirmReservation" class="btn btn-primary" disabled>Confirm Reservation <span id="totalSelected">(0)</span></button>
  </div>
</div>