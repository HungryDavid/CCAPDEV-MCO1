

<div class="container mt-4">
  {{#if reservation}}
    <input type="hidden" id="reservationId" value="{{reservation._id}}">
  {{/if}}

  <h2>{{#if reservation}}Edit Reservation{{else}}New Reservation{{/if}}</h2>
  <p><strong>Date:</strong> {{selectedDate}}</p>

  <!-- TIME SELECT FORM -->
  <form id="timeSelectForm" method="GET"
    action="/labs/slots-availability/{{lab.name}}?bookingDate={{selectedDate}}&bookingTime={{selectedTime}}">
    <input type="hidden" name="bookingDate" value="{{selectedDate}}" id="bookingDate">
    <input type="hidden" id="labNameInput" value="{{lab.name}}">

    <div class="row mb-3">
      <div class="col-md-4">
        <label class="form-label">Select Time:</label>
        <select class="form-select" name="bookingTime" id="bookingTime">
          {{#each timeSlotsArray}}
          <option value="{{this}}" {{#if (eq this ../selectedTime)}}selected{{/if}}>
            {{this}}
          </option>
          {{/each}}
        </select>
      </div>
    </div>

    <input type="hidden" name="cartData" id="cartDataInput" />
  </form>

  <!-- SEAT GRID -->
  <div class="row" id="seatGrid">
    {{#each labSeats}}
    <div class="col-md-2 col-3 mb-2">
      <button
        class="btn seat-btn w-100 {{#if (isSeatSelected reservationSeats ../selectedTime this.seatNumber)}}btn-success{{else if (eq this.status 'reserved')}}btn-outline-danger{{else}}btn-outline-primary{{/if}}"
        data-seat="{{this.seatNumber}}"
        data-booking-time="{{../bookingTime}}"
        {{#unless (isSeatSelected reservationSeats ../selectedTime this.seatNumber)}}
          {{#if (eq this.status 'reserved')}}disabled{{/if}}
        {{/unless}}
        title="{{#if (isSeatSelected reservationSeats ../selectedTime this.seatNumber)}}Selected{{else if (eq this.status 'reserved')}}{{this.user.name}}{{else}}Available{{/if}}">

        {{#if (isSeatSelected reservationSeats ../selectedTime this.seatNumber)}}
          {{this.seatNumber}}
        {{else if (eq this.status 'reserved')}}
          {{this.user.name}}
        {{else}}
          {{this.seatNumber}}
        {{/if}}
      </button>
    </div>
    {{/each}}
  </div>

  <!-- Add To Cart -->
  <div class="text-center mt-3">
    <button id="cart" class="btn btn-success">
      Add to Cart
    </button>
  </div>

  <!-- Table for Selected Seats -->
  <div class="mt-4" id="selectedSeatsTableContainer">
    <h5>Selected Seats:</h5>
    <table class="table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Seat Number</th>
          <th>Status</th>
          <th>Action</th> <!-- Delete column -->
        </tr>
      </thead>
      <tbody id="selectedSeatsTableBody">

        <!-- Selected seats will be dynamically inserted here -->
      </tbody>
    </table>

    <!-- Confirm Reservation Button -->
    <div class="text-center mt-3">
      <button id="confirmReservationBtn" class="btn btn-success">
        {{#if reservation}}Update Reservation{{else}}Confirm Reservation{{/if}}
      </button>
    </div>
  </div>

  <!-- Load External JS -->
  <script>
    window.initialCart = {{{json reservationSeats}}};
    console.log("Initial Cart from server:", window.initialCart);
  </script>

  <script src="/js/lab-details.js"></script>