<div class="container-fluid py-3 px-3 px-md-4">
    <div class="row justify-content-center" id="reservations-container" data-role="student">
        <div class="col-12 col-sm-11 col-md-10 col-lg-8">

            <h1 class="fw-semibold fs-4 text-center pb-3 pt-2">
                Current Reservations
            </h1>

            <div class="d-md-none">
                {{#if reservations}}
                {{#each reservations}}
                <div class="card mb-3 shadow-sm border-0 rounded-3">
                    <div class="card-body p-3">
                        <h6 class="fw-bold text-primary mb-2">#{{this._id}}</h6>
                        <div class="mb-2">
                            <small class="text-muted d-block">
                                DateTime Requested: {{this.reservedAt}}
                            </small>
                            <small class="text-muted d-block">
                                Booking Date: {{this.reservationDate}}
                            </small>
                            <small class="text-muted d-block">
                                Booking Time: {{this.time}}
                            </small>
                            <small class="text-muted d-block">
                                Lab & Seat#: {{this.labId}} #{{this.seatNumbers}}
                            </small>
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <a href="/reservation/{{this.reservedAt}}/edit"
                                class="btn btn-sm btn-outline-primary rounded-2 flex-fill d-flex align-items-center justify-content-center gap-1"
                                title="Edit reservation" aria-label="Edit reservation for {{this.labId}}">
                                <i class="bi bi-pencil-square"></i>
                                <span>Edit</span>
                            </a>
                            <button type="button"
                                class="btn btn-sm btn-outline-danger rounded-2 flex-fill d-flex align-items-center justify-content-center gap-1"
                                data-bs-toggle="modal" data-bs-target="#deleteReservationModal"
                                data-id="{{this._id}}" data-laboratory="{{this.labId}}"
                                data-date="{{this.reservationDate}}" data-time="{{this.timeSlots}}" title="Delete reservation"
                                aria-label="Delete reservation for {{this.labId}}">
                                <i class="bi bi-trash3"></i>
                                <span>Delete</span>
                            </button>
                        </div>
                    </div>
                </div>
                {{/each}}
                {{else}}
                <p>No Current Reservations</p>
                {{/if}}
            </div>
            <!--Desktop-->

            <div class="d-none d-md-block table-responsive rounded-3 shadow-sm">
                <table class="table table-bordered table-hover align-middle mb-0">
                    <thead class="table-success">
                        <tr>
                            <th scope="col" class="fw-semibold">Reservation ID</th>
                            <th scope="col" class="fw-semibold">DateTime Requested</th>
                            <th scope="col" class="fw-semibold">Date</th>
                            <th scope="col" class="fw-semibold">Time</th>
                            <th scope="col" class="fw-semibold">Laboratory</th>
                            <th scope="col" class="fw-semibold">Seat#</th>
                            <th scope="col" class="fw-semibold text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if reservations}}
                        {{#each reservations}}
                        <tr>
                            <td>{{this._id}}</td>
                            <td>{{this.reservedAt}}</td>
                            <td>{{this.reservationDate}}</td>
                            <td>{{this.timeSlots}}</td>
                            <td>{{this.labId}}</td>
                            <td>{{this.seatNumbers}}</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <form method="POST" action="/labs/slots-availability/{{this.labId}}">
                                        <input type="hidden" name="reservationId" value="{{this._id}}" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                            Edit
                                        </button>
                                    </form>

                                    <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal"
                                        data-bs-target="#deleteReservationModal" data-id="{{this._id}}"
                                        data-laboratory="{{this.labId}}" data-date="{{this.reservationDate}}"
                                        data-time="{{this.timeSlots}}">
                                        Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                        {{/each}}
                        {{else}}
                        No Current Reservations
                        {{/if}}
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!--delete modal-->

<div class="modal fade" id="deleteReservationModal" tabindex="-1" aria-labelledby="deleteReservationModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-3 rounded-md-4 shadow">

            <div class="modal-header border-0 pb-2 pb-sm-0">
                <h5 class="modal-title fw-bold text-danger fs-6 fs-sm-5" id="deleteReservationModalLabel">
                    Delete Reservation
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body pt-2 pt-sm-3">
                <p class="mb-2 small">Are you sure you want to delete this reservation?</p>
            </div>

            <div class="modal-footer border-0 pt-0 d-flex flex-column flex-sm-row gap-2">
                <button type="button" class="btn btn-secondary rounded-2 rounded-md-3 w-100 order-2 order-sm-1"
                    data-bs-dismiss="modal">
                    Cancel
                </button>

                <form id="delete-reservation-form" action="/reservation/delete" method="POST"
                    class="w-100 order-1 order-sm-2">
                    <input type="hidden" name="id" id="delete-reservation-id" /> <!-- NEW -->
                    <button type="submit" class="btn btn-danger rounded-2 rounded-md-3 w-100">
                        <i class="bi bi-trash3 me-1"></i>
                        Yes, Delete
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/reservation-modal.js"></script>