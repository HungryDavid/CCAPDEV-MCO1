<div class="container-fluid py-3 px-3 px-md-4">
    <div class="row justify-content-center" id="reservations-container" data-role="student">
        <div class="col-12 col-sm-11 col-md-10 col-lg-8">

            <h1 class="fw-semibold fs-4 text-center pb-3 pt-2">
                Current Reservations
            </h1>

            <div class="d-md-none">
                {{#if reservations}}
                {{#each reservations}}
                <div class="card mb-3 shadow-sm border-0 rounded-3">
                    <div class="card-body p-3">
                        <h6 class="fw-bold text-primary mb-2">#{{this.reservationId}}</h6>
                        <div class="mb-2">
                            <small class="text-muted d-block">
                                DateTime Requested: {{this.dateTimeCreated}}
                            </small>
                            <small class="text-muted d-block">
                                Booking Date: {{this.date}}
                            </small>
                            <small class="text-muted d-block">
                                Booking Time: {{this.time}}
                            </small>
                            <small class="text-muted d-block">
                                Lab & Seat#: {{this.laboratory}} #{{this.seats}}
                            </small>
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <button type="button"
                                class="btn btn-sm btn-outline-primary rounded-2 flex-fill d-flex align-items-center justify-content-center gap-1"
                                data-bs-toggle="modal" data-bs-target="#editReservationModal" data-id="{{this.reservationId}}"
                                data-laboratory="{{this.laboratory}}" data-date="{{this.date}}"
                                data-time="{{this.time}}" title="Edit reservation"
                                aria-label="Edit reservation for {{this.laboratory}}">
                                <i class="bi bi-pencil-square"></i>
                                <span>Edit</span>
                            </button>
                            <button type="button"
                                class="btn btn-sm btn-outline-danger rounded-2 flex-fill d-flex align-items-center justify-content-center gap-1"
                                data-bs-toggle="modal" data-bs-target="#deleteReservationModal" data-id="{{this.reservationId}}"
                                data-laboratory="{{this.laboratory}}" data-date="{{this.date}}"
                                data-time="{{this.time}}" title="Delete reservation"
                                aria-label="Delete reservation for {{this.laboratory}}">
                                <i class="bi bi-trash3"></i>
                                <span>Delete</span>
                            </button>
                        </div>
                    </div>
                </div>
                {{/each}}
                {{else}}
                <p>No Current Reservations</p>
                {{/if}}
            </div>
            <!--Desktop-->

            <div class="d-none d-md-block table-responsive rounded-3 shadow-sm">
                <table class="table table-bordered table-hover align-middle mb-0">
                    <thead class="table-success">
                        <tr>
                            <th scope="col" class="fw-semibold">Reservation ID</th>
                            <th scope="col" class="fw-semibold">DateTime Requested</th>
                            <th scope="col" class="fw-semibold">Date</th>
                            <th scope="col" class="fw-semibold">Time</th>
                            <th scope="col" class="fw-semibold">Laboratory</th>
                            <th scope="col" class="fw-semibold">Seat#</th>
                            <th scope="col" class="fw-semibold text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if reservations}}
                        {{#each reservations}}
                        <tr>
                            <td>{{this.reservationId}}</td>
                            <td>{{this.dateTimeCreated}}</td>
                            <td>{{this.date}}</td>
                            <td>{{this.time}}</td>
                            <td>{{this.laboratory}}</td>
                            <td>{{this.seats}}</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                                        data-bs-target="#editReservationModal" data-id="{{this.reservationId}}"
                                        data-laboratory="{{this.laboratory}}" data-date="{{this.date}}"
                                        data-time="{{this.time}}">
                                        Edit
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal"
                                        data-bs-target="#deleteReservationModal" data-id="{{this.reservationId}}"
                                        data-laboratory="{{this.laboratory}}" data-date="{{this.date}}"
                                        data-time="{{this.time}}">
                                        Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                        {{/each}}
                        {{else}}
                        No Current Reservations
                        {{/if}}
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>


<!--edit modal-->


<div class="modal fade" id="editReservationModal" tabindex="-1" aria-labelledby="editReservationModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-3 rounded-md-4 shadow">

            <div class="modal-header border-0 pb-2 pb-sm-0">
                <h5 class="modal-title fw-bold fs-6 fs-sm-5" id="editReservationModalLabel">
                    <i class="bi bi-pencil-square text-primary me-2"></i>
                    Edit Reservation
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body pt-3">
                <form id="edit-reservation-form" action="/reservations/update" method="POST">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}" />
                    <input type="hidden" name="_method" value="PUT" />
                    <input type="hidden" name="id" id="edit-reservation-id" />

                    {{! Laboratory }}
                    <div class="mb-3">
                        <label for="edit-laboratory" class="form-label fw-semibold small">
                            Laboratory
                        </label>
                        <input type="text" class="form-control rounded-2 rounded-md-3" id="edit-laboratory"
                            name="laboratory" placeholder="e.g. GK302" required />
                    </div>

                    {{! Date }}
                    <div class="mb-3">
                        <label for="edit-date" class="form-label fw-semibold small">
                            Date
                        </label>
                        <input type="date" class="form-control rounded-2 rounded-md-3" id="edit-date" name="date"
                            required />
                    </div>

                    {{! Time }}
                    <div class="mb-3">
                        <label for="edit-time" class="form-label fw-semibold small">
                            Time Slot
                        </label>
                        <input type="text" class="form-control rounded-2 rounded-md-3" id="edit-time" name="time"
                            placeholder="e.g. 07:30AM – 08:00AM" required />
                    </div>

                </form>
            </div>

            <div class="modal-footer border-0 pt-0 d-flex flex-column flex-sm-row gap-2">
                <button type="button" class="btn btn-secondary rounded-2 rounded-md-3 w-100 order-2 order-sm-1"
                    data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="submit" form="edit-reservation-form"
                    class="btn btn-primary rounded-2 rounded-md-3 w-100 order-1 order-sm-2">
                    <i class="bi bi-floppy me-1"></i>
                    Save Changes
                </button>
            </div>

        </div>
    </div>
</div>


<!--delete modal-->

<div class="modal fade" id="deleteReservationModal" tabindex="-1" aria-labelledby="deleteReservationModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-3 rounded-md-4 shadow">

            <div class="modal-header border-0 pb-2 pb-sm-0">
                <h5 class="modal-title fw-bold text-danger fs-6 fs-sm-5" id="deleteReservationModalLabel">
                    Delete Reservation
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body pt-2 pt-sm-3">
                <p class="mb-2 small">Are you sure you want to delete this reservation?</p>
            </div>

            <div class="modal-footer border-0 pt-0 d-flex flex-column flex-sm-row gap-2">
                <button type="button" class="btn btn-secondary rounded-2 rounded-md-3 w-100 order-2 order-sm-1"
                    data-bs-dismiss="modal">
                    Cancel
                </button>

                <form id="delete-reservation-form" action="/reservation/delete" method="POST"
                    class="w-100 order-1 order-sm-2">
                    <input type="hidden" name="id" id="delete-reservation-id" /> <!-- NEW -->
                    <button type="submit" class="btn btn-danger rounded-2 rounded-md-3 w-100">
                        <i class="bi bi-trash3 me-1"></i>
                        Yes, Delete
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/reservation-modal.js"></script>