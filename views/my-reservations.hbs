<div class="container-fluid py-3 px-3 px-md-4">
    <div class="row justify-content-center" id="reservations-container" data-role="student">
        <div class="col-12 col-sm-11 col-md-10 col-lg-8">

            <h1 class="fw-semibold fs-4 text-center pb-3 pt-2">
                Current Reservations
            </h1>

            <div class="d-md-none">
                {{#if reservations}}
                {{#each reservations}}
                <div class="card mb-3 shadow-sm border-0 rounded-3">
                    <div class="card-body p-3">
                        <h6 class="fw-bold text-primary mb-2">#{{this._id}}</h6>
                        <div class="mb-2">
                            <small class="text-muted d-block">
                                DateTime Requested: {{formatDate this.createdAt}}
                            </small>
                            <small class="text-muted d-block">
                                Booking Date: {{formatDate this.date}}
                            </small>
                            <small class="text-muted d-block">
                                Laboratory: {{this.laboratory.name}}
                            </small>
                            <small class="text-muted d-block">
                                Booking Time: {{#each this.slots}}{{minutesToTime this.startTime}}-{{minutesToTime
                                this.endTime}}, {{/each}}
                            </small>
                            <small class="text-muted d-block">
                                Seat: {{#each this.slots}}#{{this.seatNumber}}, {{/each}}
                            </small>
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <form method="GET" action="/reservation/{{this._id}}/update" class="flex-fill">
                            <button type="submit" class="btn btn-outline-primary w-100 rounded-3 d-flex align-items-center justify-content-center gap-2">
                                <span>Edit</span>
                            </button>
                            </form>
                            <button type="button"
                                class="btn btn-sm btn-outline-danger rounded-2 flex-fill d-flex align-items-center justify-content-center gap-1"
                                data-bs-toggle="modal" data-bs-target="#deleteReservationModal" data-id="{{this._id}}"
                                data-laboratory="{{this.laboratory}}" data-date="{{this.date}}"
                                data-time="{{this.time}}" title="Delete reservation"
                                aria-label="Delete reservation for {{this.laboratory}}">
                                <span>Delete</span>
                            </button>
                        </div>
                    </div>
                </div>
                {{/each}}
                {{else}}
                <p>No Current Reservations</p>
                {{/if}}
            </div>
        </div>

        <!--Desktop Current Reservation-->
        <div class="d-none d-md-block table-responsive rounded-3 shadow-sm">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="table-success">
                    <tr>
                        <th scope="col" class="fw-semibold">Reservation ID</th>
                        <th scope="col" class="fw-semibold">DateTime Requested</th>
                        <th scope="col" class="fw-semibold">Date</th>
                        <th scope="col" class="fw-semibold">Time</th>
                        <th scope="col" class="fw-semibold">Laboratory</th>
                        <th scope="col" class="fw-semibold">Seat#</th>
                        <th scope="col" class="fw-semibold text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    {{#if reservations}}
                    {{#each reservations}}
                    <tr>
                        <td>{{this._id}}</td>
                        <td>{{formatDate this.createdAt}}</td>
                        <td>{{this.date}}</td>
                        <td>{{#each this.slots}}{{minutesToTime this.startTime}}-{{minutesToTime
                            this.endTime}}<br>{{/each}}</td>
                        <td>{{this.laboratory.name}}</td>
                        <td>{{#each this.slots}}#{{this.seatNumber}}<br>{{/each}}</td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <form method="GET" action="/reservation/{{this._id}}/update">
                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </button>
                                </form>

                                <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal"
                                    data-bs-target="#deleteReservationModal" data-id="{{this._id}}"
                                    data-laboratory="{{this.laboratory}}" data-date="{{this.date}}"
                                    data-time="{{this.time}}">
                                    Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                    {{else}}
                    No Current Reservations
                    {{/if}}
                </tbody>
            </table>
        </div>


        <!--Mobile Past Reservation-->
        <div class="col-12 col-sm-11 col-md-10 col-lg-8">

            <h1 class="fw-semibold fs-4 text-center pb-3 pt-2">
                Past Reservations
            </h1>

            <div class="d-md-none">
                {{#if pastReservations}}
                {{#each pastReservations}}
                <div class="card mb-3 shadow-sm border-0 rounded-3">
                    <div class="card-body p-3">

                        <h6 class="fw-bold text-secondary mb-2">#{{this._id}}</h6>

                        <div class="mb-2">
                            <small class="text-muted d-block">
                                DateTime Requested: {{formatDate this.createdAt}}
                            </small>
                            <small class="text-muted d-block">
                                Booking Date: {{this.date}}
                            </small>
                            <small class="text-muted d-block">
                                Laboratory: {{this.laboratory.name}}
                            </small>
                            <small class="text-muted d-block">
                                Booking Time: {{#each this.slots}}{{minutesToTime this.startTime}}-{{minutesToTime
                                this.endTime}}, {{/each}}
                            </small>
                            <small class="text-muted d-block">
                                Seat: {{#each this.slots}}#{{this.seatNumber}}, {{/each}}
                            </small>
                        </div>

                        <div class="mt-3 ">
                            <span class="badge bg-secondary">
                                Completed
                            </span>
                        </div>

                    </div>
                </div>
                {{/each}}
                {{else}}
                <p class="text-center text-muted">No Past Reservations</p>
                {{/if}}
            </div>
        </div>


        <!--Desktop Past Reservation-->
        <div class="d-none d-md-block table-responsive rounded-3 shadow-sm">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th class="fw-semibold">Reservation ID</th>
                        <th class="fw-semibold">DateTime Requested</th>
                        <th class="fw-semibold">Date</th>
                        <th class="fw-semibold">Time</th>
                        <th class="fw-semibold">Laboratory</th>
                        <th class="fw-semibold">Seat#</th>
                        <th class="fw-semibold text-center">Status</th>
                    </tr>
                </thead>

                <tbody>
                    {{#if pastReservations}}
                    {{#each pastReservations}}
                    <tr>
                        <td>{{this._id}}</td>
                        <td>{{formatDate this.createdAt}}</td>
                        <td>{{this.date}}</td>
                        <td>{{#each this.slots}}{{minutesToTime this.startTime}}-{{minutesToTime
                            this.endTime}}<br>{{/each}}
                        </td>
                        <td>{{this.laboratory.name}}</td>
                        <td>{{#each this.slots}}#{{this.seatNumber}}<br>{{/each}}</td>
                        <td class="text-center">
                            <span class="badge bg-secondary">
                                Completed
                            </span>
                        </td>
                    </tr>
                    {{/each}}
                    {{else}}
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            No Past Reservations
                        </td>
                    </tr>
                    {{/if}}
                </tbody>

            </table>
        </div>

    </div>

    <!--delete modal-->

    <div class="modal fade" id="deleteReservationModal" tabindex="-1" aria-labelledby="deleteReservationModalLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-3 rounded-md-4 shadow">

                <div class="modal-header border-0 pb-2 pb-sm-0">
                    <h5 class="modal-title fw-bold text-danger fs-6 fs-sm-5" id="deleteReservationModalLabel">
                        Delete Reservation
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-2 pt-sm-3">
                    <p class="mb-2 small">Are you sure you want to delete this reservation?</p>
                </div>

                <div class="modal-footer border-0 pt-0 d-flex flex-column flex-sm-row gap-2">
                    <button type="button" class="btn btn-secondary rounded-2 rounded-md-3 w-100 order-2 order-sm-1"
                        data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <form id="delete-reservation-form" action="/reservation/delete" method="POST"
                        class="w-100 order-1 order-sm-2">
                        <input type="hidden" name="id" id="delete-reservation-id" /> <!-- NEW -->
                        <button type="submit" class="btn btn-danger rounded-2 rounded-md-3 w-100">
                            Yes, Delete
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/reservation-modal.js"></script>